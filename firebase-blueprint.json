{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A website project being monitored.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the project." },
        "apiUrl": { "type": "string", "description": "The URL to fetch logs from." },
        "apiKey": { "type": "string", "description": "Optional API key for secure access." },
        "description": { "type": "string", "description": "Optional description." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "createdBy": { "type": "string", "description": "UID of the creator." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Current status." }
      },
      "required": ["name", "apiUrl", "createdAt", "createdBy", "status"]
    },
    "LogEntry": {
      "title": "Log Entry",
      "description": "A single log record from a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the parent project." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the log occurred." },
        "level": { "type": "string", "enum": ["info", "warn", "error", "debug"], "description": "Severity level." },
        "message": { "type": "string", "description": "The log message." },
        "metadata": { "type": "object", "description": "Additional context." }
      },
      "required": ["projectId", "timestamp", "level", "message"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "description": "User email." },
        "displayName": { "type": "string", "description": "User display name." },
        "role": { "type": "string", "enum": ["admin", "viewer"], "description": "User role." },
        "assignedProjects": { "type": "array", "items": { "type": "string" }, "description": "List of project IDs the user can see." }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of monitored projects."
    },
    "/projects/{projectId}/logs/{logId}": {
      "schema": "LogEntry",
      "description": "Logs for a specific project."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions."
    }
  }
}
