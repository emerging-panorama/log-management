rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (admin | viewer)
    //   - assignedProjects: list (project IDs)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - name: string (required)
    //   - apiUrl: string (required)
    //   - apiKey: string
    //   - description: string
    //   - createdAt: timestamp (required)
    //   - createdBy: string (required)
    //   - status: string (active | inactive)
    //
    // Collection: projects/{projectId}/logs
    // Document ID: {logId}
    // Fields:
    //   - projectId: string (required)
    //   - timestamp: timestamp (required)
    //   - level: string (info | warn | error | debug)
    //   - message: string (required)
    //   - metadata: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "Vishnuvvp007@gmail.com") || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasProjectAccess(projectId) {
      return isAdmin() || 
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         projectId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedProjects);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'viewer'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'apiUrl', 'createdAt', 'createdBy', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.apiUrl is string && data.apiUrl.size() > 0 &&
             data.status in ['active', 'inactive'];
    }

    function isValidLog(data) {
      return data.keys().hasAll(['projectId', 'timestamp', 'level', 'message']) &&
             data.projectId is string &&
             data.level in ['info', 'warn', 'error', 'debug'] &&
             data.message is string && data.message.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'viewer' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /projects/{projectId} {
      allow list: if isAuthenticated();
      allow get: if hasProjectAccess(projectId);
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read: if hasProjectAccess(projectId);
        allow create: if isAuthenticated() && isValidLog(request.resource.data); // Allow logs to be written by authenticated users (or system)
        allow delete: if isAdmin();
      }
    }
  }
}
